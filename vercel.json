{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["*.html", "style.css", "script.js", "dashboard.html", "room.html", "index.html", "public/**", "routes/**", "lib/**", "db.js"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
